# GitHub Actions / flyctl
FLY_API_TOKEN=your-fly-api-token

# Fly Postgres app secret (trythissoftware-db)
POSTGRES_PASSWORD=your-postgres-password

# Fly API app secrets (trythissoftware-api)
DATABASE_URL=postgresql://postgres:changeme@trythissoftware-db.flycast:5432/rustgit
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
JWT_SECRET=your-jwt-secret
REDIS_URL=redis://your-redis-host:6379

# Fly app env defaults
BASE_DOMAIN=trythissoftware.com
NEXT_PUBLIC_API_URL=https://api.trythissoftware.com
NEXT_PUBLIC_BASE_DOMAIN=trythissoftware.com
